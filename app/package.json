{
  "name": "@pokeworld/app",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Pokémon World — unified Nitro, React Router, and durable map-generation application package.",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && node scripts/finalize-static-shell.mjs",
    "build:vercel": "NITRO_PRESET=vercel vite build && NITRO_PRESET=vercel node scripts/finalize-static-shell.mjs && node scripts/verify-vercel-output.mjs",
    "preview": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm test && pnpm build:vercel",
    "pms": "node scripts/pm2.mjs start",
    "pms-stop": "node scripts/pm2.mjs stop",
    "workflow:inspect": "workflow inspect runs",
    "workflow:web": "workflow web",
    "map:generate": "node scripts/map/generate-map.mjs"
  },
  "dependencies": {
    "dotenv": "17.2.3",
    "mongodb": "7.5.0",
    "nitro": "3.0.260610-beta",
    "pngjs": "7.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.2.0",
    "throttled-queue": "2.1.2",
    "uuid": "9.0.1",
    "workflow": "4.6.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.4",
    "jiti": "2.7.0",
    "postcss": "8.5.19",
    "sass": "1.101.0",
    "tailwindcss": "3.4.19",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "license": "ISC"
}
