# One root port serves the React UI, Nitro API routes, and local Workflow runtime.
PORT=3847
WORKFLOW_TARGET_WORLD=local
WORKFLOW_LOCAL_BASE_URL=http://127.0.0.1:3847
POKEWORLD_OFFLINE_MAP=false

# Thingtime is the production database for complete 16x16 map blocks and the
# global generation quota. This is the private token for @pokeworld-service;
# never expose it through VITE_* or commit a real value.
THINGTIME_SERVICE_TOKEN=
THINGTIME_API_URL=https://thingtime.com
THINGTIME_API_TIMEOUT_MS=15000

# Optional legacy local-development fallback. Public/Vercel builds never use
# MongoDB for map storage when the Thingtime service account is configured.
MONGODB_URI=mongodb+srv://username:password@example.mongodb.net/pokeworld?retryWrites=true&w=majority
MONGODB_DB=pokeworld

# Optional Google Static Maps key. Without it, generation uses a deterministic
# solid-colour fallback and records fallback provenance for later regeneration.
GOOGLE_API_KEY=replace-with-google-static-maps-key

# Thingtime SSO. The client ID is public and is created by registering each
# exact Pokeworld origin with Thingtime. The session secret must be a random
# value of at least 32 characters and must stay server-side.
VITE_THINGTIME_CLIENT_ID=ttapp_replace-with-pokeworld-client-id
POKEWORLD_SESSION_SECRET=replace-with-a-random-secret-of-at-least-32-characters

# Optional comma-separated immutable Thingtime user IDs with Pokeworld admin
# access. Thingtime user @lopu is always recognized by its immutable ID.
POKEWORLD_ADMIN_THINGTIME_IDS=
